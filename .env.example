NODE_ENV=development

POSTGRES_USER=mini_sentry
POSTGRES_PASSWORD=mini_sentry
POSTGRES_DB=mini_sentry
POSTGRES_PORT=5433
DATABASE_URL=postgresql://mini_sentry:mini_sentry@localhost:5433/mini_sentry
TEST_DATABASE_URL=postgresql://mini_sentry:mini_sentry@localhost:5433/mini_sentry_test

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

JWT_ACCESS_SECRET=replace-with-local-access-secret
JWT_REFRESH_SECRET=replace-with-local-refresh-secret

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@mini-sentry.local

SLACK_WEBHOOK_URL=

API_PORT=4000
DASHBOARD_PORT=5173
CORS_ORIGIN=http://localhost:5173
DSN_HOST=localhost:4000
DSN_SCHEME=http

# Retention / pruning (P0). days=0 disables that target (NOT delete-all).
RETENTION_ENABLED=true
RETENTION_REPLAY_DAYS=14
RETENTION_SNAPSHOT_DAYS=14
RETENTION_EVENT_DAYS=90
RETENTION_BATCH_SIZE=1000
RETENTION_CRON=0 3 * * *
