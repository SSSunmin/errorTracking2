generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IssueLevel {
  debug
  info
  warning
  error
  fatal
}

enum IssueStatus {
  unresolved
  resolved
  ignored
}

enum AlertChannel {
  email
  slack
}

enum AlertCondition {
  new_issue
  regression
  event_threshold
}

enum NotificationStatus {
  pending
  sent
  failed
}

enum ProjectRole {
  owner
  member
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  projects      Project[]
  memberships   ProjectMember[]
  refreshTokens RefreshToken[]
}

model Project {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  platform   String       @default("javascript-browser")
  ownerId    String
  owner      User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  keys       ProjectKey[]
  issues     Issue[]
  events     Event[]
  alertRules AlertRule[]
  sourceMaps SourceMap[]
  members    ProjectMember[]

  @@index([ownerId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectRole @default(member)
  createdAt DateTime    @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectKey {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publicKey  String    @unique
  label      String?
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([projectId])
}

model Issue {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fingerprint   String
  title         String
  culprit       String?
  level         IssueLevel     @default(error)
  status        IssueStatus    @default(unresolved)
  timesSeen     Int            @default(0)
  firstSeen     DateTime
  lastSeen      DateTime
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  events        Event[]
  notifications Notification[]

  @@unique([projectId, fingerprint])
  @@index([projectId, status])
  @@index([projectId, lastSeen])
}

model Event {
  id             String     @id @default(cuid())
  issueId        String
  issue          Issue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  message        String?
  exceptionType  String?
  exceptionValue String?
  stacktrace     Json?
  symbolicated   Json?
  breadcrumbs    Json?
  tags           Json?
  userContext    Json?
  contexts       Json?
  level          IssueLevel
  environment    String?
  release        String?
  sdkName        String?
  sdkVersion     String?
  requestUrl     String?
  userAgent      String?
  timestamp      DateTime
  receivedAt     DateTime   @default(now())
  clientEventId  String?
  snapshot       EventSnapshot?

  @@index([issueId, receivedAt])
  @@index([projectId, receivedAt])
  @@index([clientEventId])
}

model EventSnapshot {
  id        String   @id @default(cuid())
  eventId   String   @unique
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  projectId String
  data      Json
  href      String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model EventReplay {
  id            String   @id @default(cuid())
  clientEventId String   @unique
  projectId     String
  data          Bytes
  eventCount    Int?
  durationMs    Int?
  sizeBytes     Int?
  createdAt     DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model SourceMap {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release   String
  filename  String
  data      Bytes
  sizeBytes Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, release, filename])
  @@index([projectId, release])
}

model AlertRule {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  channel       AlertChannel
  target        String
  condition     AlertCondition
  threshold     Int?
  windowMinutes Int?
  cooldownMinutes Int?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]

  @@index([projectId])
}

model Notification {
  id          String             @id @default(cuid())
  alertRuleId String
  alertRule   AlertRule          @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  issueId     String
  issue       Issue              @relation(fields: [issueId], references: [id], onDelete: Cascade)
  channel     AlertChannel
  status      NotificationStatus
  error       String?
  sentAt      DateTime           @default(now())

  @@index([alertRuleId, issueId])
}

model RefreshToken {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash           String    @unique
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedByTokenHash String?
  createdAt           DateTime  @default(now())

  @@index([userId])
}
