{
  "name": "@mini-sentry/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "db:seed": "dotenv -e ../../.env -- prisma db seed",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/rate-limit": "11.0.0",
    "@prisma/client": "6.19.3",
    "argon2": "0.44.0",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "fastify-plugin": "5.1.0",
    "fastify-type-provider-zod": "6.1.0",
    "jose": "6.2.3",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "dotenv-cli": "10.0.0",
    "pg": "8.21.0",
    "pino-pretty": "13.1.3",
    "prisma": "6.19.3",
    "tsx": "4.22.4"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  }
}
