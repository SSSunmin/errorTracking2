# Dashboard build-time env (Vite). Loaded from packages/dashboard/.env — NOT the
# repo-root .env (Vite's envDir is this package). Only VITE_-prefixed vars are
# exposed to the client bundle.

# Backend target the dev server proxies /api to. Default: http://localhost:4100
VITE_API_TARGET=http://localhost:4100

# Separate origin that serves the replay viewer (replay-viewer.html), isolating
# untrusted recordings from the dashboard origin (token, DOM, /api). When EMPTY
# (default, incl. local dev) replays/snapshots render in-page behind rrweb's
# no-allow-scripts sandbox. Set in staging/prod, e.g. https://replay.example.com
# NOTE: at the serving layer (Caddy) also send a `Content-Security-Policy:
# frame-ancestors <dashboard-origin>` header on the viewer — <meta> cannot set it.
# 운영 배포 구성(별도 오리진 서빙·frame-ancestors·compose)은 deploy/ 및
# knowledge/ops/deployment.md 참고.
VITE_REPLAY_ORIGIN=
