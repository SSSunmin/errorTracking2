{
  "name": "@mini-sentry/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "node --watch src/index.ts",
    "prepack": "npm run build",
    "typecheck": "tsc -b"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
