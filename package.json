{
  "name": "mini-sentry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "eslint": "9.39.1",
    "jsdom": "25.0.1",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4",
    "vitest": "3.2.6"
  }
}
