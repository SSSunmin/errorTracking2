# Mini-Sentry 운영(prod) 환경변수 예시.
#   cp .env.prod.example .env.prod   후 값 채우기. .env.prod는 절대 커밋 금지(.gitignore 등록됨).
# docker-compose.prod.yml이 env_file로 server/worker/migrate에 주입하고,
# DASHBOARD_DOMAIN/REPLAY_DOMAIN/API_PORT/VITE_REPLAY_ORIGIN은 caddy(빌드+런타임)에도 쓰인다.

# ── 도메인 ────────────────────────────────────────────────────────────────────
# 운영 VPS의 실제 도메인. Caddy가 이 둘로 사이트블록을 만들고 자동 TLS를 발급한다.
# 반드시 "호스트명만" — 스킴(https://)·끝슬래시 금지. Caddyfile이 frame-ancestors에
# https://를 직접 붙이므로 https://dash... 로 쓰면 https://https://… 가 되어 리플레이
# iframe이 조용히 차단된다.
DASHBOARD_DOMAIN=dash.example.com
REPLAY_DOMAIN=replay.example.com

# ── 실행 모드 ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=mini_sentry
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=mini_sentry
# DATABASE_URL은 compose 내부 네트워크의 postgres 서비스를 가리킨다(호스트 5432 아님).
# user/password/db를 위 값과 일치시킬 것.
DATABASE_URL=postgresql://mini_sentry:change-me-strong-db-password@postgres:5432/mini_sentry

# ── Redis ─────────────────────────────────────────────────────────────────────
# compose 내부 네트워크의 redis 서비스.
REDIS_URL=redis://redis:6379

# ── JWT 시크릿 (각각 최소 32자) ─────────────────────────────────────────────────
# 예: openssl rand -base64 48 로 생성. 아래는 placeholder(반드시 교체).
JWT_ACCESS_SECRET=replace-with-32+char-random-access-secret
JWT_REFRESH_SECRET=replace-with-32+char-random-refresh-secret

# ── 서버/오리진 ────────────────────────────────────────────────────────────────
API_PORT=4000
# prod 필수. 대시보드 도메인(https). server가 부팅 시 검증한다.
CORS_ORIGIN=https://dash.example.com
# DSN 호스트/스킴(SDK가 이벤트를 보낼 인입 엔드포인트). prod는 https.
DSN_HOST=dash.example.com
DSN_SCHEME=https

# ── 대시보드 빌드 ARG ──────────────────────────────────────────────────────────
# 빌드타임 변수(Vite가 번들에 인라인). 리플레이 뷰어를 임베드할 별도 오리진.
# 반드시 REPLAY_DOMAIN과 일치(https). compose가 caddy 빌드 args로 전달한다.
VITE_REPLAY_ORIGIN=https://replay.example.com

# ── (선택) SMTP 이메일 알림 ─────────────────────────────────────────────────────
# 4개(HOST/PORT/USER/PASSWORD)가 모두 있어야 실제 전송. 없으면 로그 폴백.
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=no-reply@dash.example.com

# ── (선택) Retention/정리 잡 — 기본값 있음, 보통 생략 가능 ────────────────────────
#RETENTION_ENABLED=true
#RETENTION_REPLAY_DAYS=14
#RETENTION_SNAPSHOT_DAYS=14
#RETENTION_EVENT_DAYS=90
#RETENTION_BATCH_SIZE=1000
#RETENTION_CRON=0 3 * * *
